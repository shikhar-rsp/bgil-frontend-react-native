# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'Atlas' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Xcode 26's clang rejects the `fmt` (11.0.2) library's consteval
    # format-string constructors ("call to consteval function ... is not a
    # constant expression"). `fmt/base.h` defines FMT_USE_CONSTEVAL
    # unconditionally (no #ifndef), so a -D override is ignored — patch the
    # vendored header to force it to 0, which makes the constructors constexpr
    # and compiles cleanly. Re-applied on every `pod install`.
    fmt_base = File.join(installer.sandbox.root.to_s, 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base)
      contents = File.read(fmt_base)
      patched = contents.gsub('#  define FMT_USE_CONSTEVAL 1', '#  define FMT_USE_CONSTEVAL 0')
      if patched != contents
        # CocoaPods installs pod headers read-only, so make it writable first.
        File.chmod(0644, fmt_base)
        File.write(fmt_base, patched)
        puts '[Atlas] Patched fmt/base.h: FMT_USE_CONSTEVAL -> 0 (Xcode 26 fmt fix)'
      end
    end
  end
end
